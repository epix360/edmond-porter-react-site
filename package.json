{
  "name": "edmond-porter-website",
  "version": "1.0.0",
  "description": "Author website for Edmond A Porter",
  "homepage": "https://edmondaporter.com",
  "main": "src/index.js",
  "scripts": {
    "prebuild": "node scripts/generate-book-index.js && node scripts/generate-timeline-js.js && node scripts/copy-images",
    "build": "react-scripts build && node scripts/pre-render && node scripts/optimize-performance",
    "build:analyze": "npm run build && node scripts/optimize-performance",
    "start": "react-scripts start",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
