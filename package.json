{
  "name": "edmond-porter-website",
  "version": "1.0.3",
  "description": "Author website for Edmond A Porter",
  "homepage": "https://edmondaporter.com",
  "main": "src/index.js",
  "scripts": {
    "prebuild": "node scripts/generate-book-index.js && node scripts/generate-timeline-js.js && node scripts/copy-images",
    "build": "react-scripts build && node scripts/pre-render && node scripts/optimize-performance && node scripts/generate-static-pages && node scripts/generate-service-worker",
    "build:unified": "node scripts/unified-build",
    "build:analyze": "npm run build && node scripts/optimize-performance",
    "start": "react-scripts start",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev:next": "node --no-deprecation scripts/build-next.js dev",
    "build:next": "node scripts/build-next.js build",
    "build:next:direct": "next build",
    "start:next": "next start"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "next": "^16.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.3.0",
    "react-scripts": "5.0.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
